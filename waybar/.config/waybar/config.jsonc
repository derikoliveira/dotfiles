{
  "include": [
    "~/.config/waybar/custom-modules.jsonc",
    "~/.config/waybar/default-modules.jsonc",
  ],
  "layer": "top",
  "position": "top",
  // "height": 100,
  "spacing": 4,
  "modules-left": ["hyprland/workspaces", "pulseaudio", "backlight"],
  "modules-center": ["hyprland/window"],
  "modules-right": [
    // "hyprland/submap",
    "cpu",
    "memory",
    "disk",
    "temperature",
    "clock",
    "custom/wlogout",
  ],
}
